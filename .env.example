# Backend origin tanpa suffix /api
NUXT_PUBLIC_API_TARGET=http://localhost:9999

# Set ke false di production agar browser langsung ke backend
# dan tidak melewati proxy Vercel untuk semua request API.
NUXT_PUBLIC_USE_API_PROXY=true

# Opsional. Biarkan kosong jika ingin base URL dihitung otomatis.
# Saat proxy aktif: /api
# Saat proxy nonaktif: ${NUXT_PUBLIC_API_TARGET}/api
# NUXT_PUBLIC_API_BASE=
